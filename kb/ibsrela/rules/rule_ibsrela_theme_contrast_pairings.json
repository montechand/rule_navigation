{
  "id": "rule_ibsrela_theme_contrast_pairings",
  "brand_id": "ibsrela",
  "rule_class": "color_application",
  "tags": [
    "accessibility",
    "typography"
  ],
  "content_types": [
    "email"
  ],
  "scope": "org_baseline",
  "selector": {},
  "applies_when": [
    {
      "kind": "background_group",
      "value": "dark"
    },
    {
      "kind": "background_group",
      "value": "light"
    }
  ],
  "evaluation_scope": "section",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "headline.color",
        "token_id": "tok_ibsrela_headline_color"
      },
      {
        "element_path": "subhead.color",
        "token_id": "tok_ibsrela_subhead_color"
      },
      {
        "element_path": "body.color",
        "token_id": "tok_ibsrela_body_color"
      },
      {
        "element_path": "body.link.color",
        "token_id": "tok_ibsrela_body_link_color"
      },
      {
        "element_path": "body.link.decoration",
        "token_id": "tok_ibsrela_body_link_decoration"
      }
    ]
  },
  "polarity": "must",
  "hardness": "hard_constraint",
  "precedence": 0,
  "token_ids": [
    "tok_ibsrela_body_color",
    "tok_ibsrela_body_link_color",
    "tok_ibsrela_body_link_decoration",
    "tok_ibsrela_headline_color",
    "tok_ibsrela_subhead_color"
  ],
  "asset_ids": [],
  "rule_text": "[BASELINE] Contrast pairings by panel: on Purple/Navy/Green panels use white text only; on White/Silver panels use navy headlines, black body, and purple accents. Links on dark panels are white underlined; on light panels purple or navy underlined. Colors resolve via the semantic text/link tokens whose background_group variants carry the light/dark switching.",
  "intent": "Ensure legible, on-brand text/link contrast for each panel background.",
  "source": "design_bible",
  "doc_ref": "color_scheme_rules[3]",
  "group_id": "grp_ibsrela_color_scheme_rules_03",
  "status": "active",
  "version": 1,
  "summary": "Apply white text and underlined white links on Purple/Navy/Green panels; navy headlines, black body, purple accents, and purple/navy underlined links on White/Silver panels."
}