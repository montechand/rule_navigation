{
  "id": "rule_ibsrela_link_color_on_dark_panels",
  "brand_id": "ibsrela",
  "rule_class": "color_application",
  "tags": [
    "accessibility"
  ],
  "content_types": [
    "email"
  ],
  "scope": "org_baseline",
  "selector": {
    "element_path": "link"
  },
  "applies_when": [
    {
      "kind": "background_group",
      "value": {
        "panels": [
          "Purple",
          "Navy",
          "Green"
        ]
      }
    }
  ],
  "evaluation_scope": "element",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "link.color",
        "token_id": "tok_ibsrela_color_white"
      }
    ]
  },
  "polarity": "must",
  "hardness": "hard_constraint",
  "precedence": 0,
  "token_ids": [
    "tok_ibsrela_color_white"
  ],
  "asset_ids": [],
  "governance_ids": [],
  "rule_text": "Links on dark panels (Purple/Navy/Green) are white and underlined.",
  "intent": "Ensure links are visible and identifiable on dark panels.",
  "source": "design_bible",
  "doc_ref": "color_scheme_rules[3]",
  "group_id": "grp_ibsrela_color_scheme_rules_03",
  "status": "active",
  "version": 1,
  "summary": "Links on dark panels (Purple, Navy, Green) must be white and underlined."
}