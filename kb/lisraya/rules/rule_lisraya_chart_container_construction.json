{
  "id": "rule_lisraya_chart_container_construction",
  "brand_id": "lisraya",
  "rule_class": "color_application",
  "tags": [
    "layout"
  ],
  "scope": "brand",
  "selector": {
    "section_types": [
      "chart"
    ],
    "element_path": "chart.container"
  },
  "evaluation_scope": "section",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "chart.container.fill",
        "token_id": "tok_lisraya_chart_container_fill"
      },
      {
        "element_path": "chart.header.fill",
        "token_id": "tok_lisraya_chart_header_fill"
      },
      {
        "element_path": "radius.chart.uniform",
        "token_id": "tok_lisraya_radius_chart_uniform"
      }
    ]
  },
  "polarity": "must",
  "hardness": "strong_default",
  "precedence": 0,
  "token_ids": [
    "tok_lisraya_chart_container_fill",
    "tok_lisraya_chart_header_fill",
    "tok_lisraya_radius_chart_uniform"
  ],
  "asset_ids": [],
  "rule_text": "Chart containers are clean, easy to scan, and consistent with the system: a Light Blue (chart.container.fill = #E6F0F9) panel with uniform rounded corners (radius.chart.uniform = 12px) and a Brand Blue (chart.header.fill = #00529b) rounded header bar.",
  "intent": "Keep charts visually consistent with the brand system.",
  "source": "design_bible",
  "doc_ref": "design_pattern_rules[4]",
  "group_id": "grp_lisraya_design_pattern_rules_04",
  "status": "active",
  "version": 1,
  "summary": "Chart containers: Light Blue fill #E6F0F9, 12px uniform rounded corners, Brand Blue header #00529b with rounded bar."
}