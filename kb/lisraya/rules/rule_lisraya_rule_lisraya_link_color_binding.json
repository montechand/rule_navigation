{
  "id": "rule_lisraya_rule_lisraya_link_color_binding",
  "brand_id": "lisraya",
  "rule_class": "color_application",
  "scope": "org_baseline",
  "selector": {
    "element_path": "body.link"
  },
  "evaluation_scope": "element",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "body.link.color",
        "token_id": "tok_lisraya_link_color"
      },
      {
        "element_path": "body.link.text_decoration",
        "token_id": "tok_lisraya_link_text_decoration"
      }
    ]
  },
  "polarity": "must",
  "hardness": "hard_constraint",
  "precedence": 0,
  "token_ids": [
    "tok_lisraya_link_color",
    "tok_lisraya_link_text_decoration"
  ],
  "asset_ids": [],
  "rule_text": "Hyperlinks must be underlined. Use Brand Blue (body.link.color = #00529b) on light backgrounds, and White (#ffffff) on dark backgrounds.",
  "intent": "Maintain accessible and cohesive interactive link styling across light and dark backgrounds.",
  "source": "design_bible",
  "doc_ref": "color_scheme_rules[1]",
  "group_id": "grp_lisraya_color_scheme_rules_01",
  "status": "active",
  "version": 1,
  "summary": "Hyperlinks underlined; Brand Blue (#00529b) on light backgrounds, White (#ffffff) on dark backgrounds."
}