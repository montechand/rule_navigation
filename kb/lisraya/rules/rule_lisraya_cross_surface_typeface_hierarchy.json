  "doc_ref": "content_pattern_rules[1]",
  "group_id": "grp_lisraya_content_pattern_rules_01",
  "status": "active",
  "version": 1,
  "summary": "Use Agenda for print headlines/headers; Nunito Sans for digital/email headlines (bolder, Title Case), print/digital body/footer; Aptos for Word/PPT/Excel text."
