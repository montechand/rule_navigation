  "asset_ids": [],
  "rule_text": "Primary CTA buttons use Brand Blue #00529b background (cta.button.fill) with White #ffffff text (cta.button.label.color), Nunito Sans Bold 16px, padding 14px 32px, minimum 48px touch-target height (brand accessibility rule: \u226548px clickable areas), and a 24px fully-rounded pill corner radius echoing the rounded brand aesthetic. Secondary CTA uses a White background, 2px Brand Blue border (cta.button.secondary.border) and Brand Blue text, with the same metrics.",
  "intent": "Lock CTA button appearance and touch-target accessibility across all sections.",
