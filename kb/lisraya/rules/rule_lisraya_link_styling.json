{
  "id": "rule_lisraya_link_styling",
  "brand_id": "lisraya",
  "rule_class": "color_application",
  "tags": [
    "typography",
    "accessibility"
  ],
  "scope": "org_baseline",
  "selector": {
    "element_path": "link"
  },
  "evaluation_scope": "element",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "link.color.on_light",
        "token_id": "tok_lisraya_color_brand_blue"
      },
      {
        "element_path": "link.color.on_dark",
        "token_id": "tok_lisraya_color_white"
      }
    ]
  },
  "polarity": "must",
  "hardness": "strong_default",
  "precedence": 0,
  "token_ids": [
    "tok_lisraya_color_brand_blue",
    "tok_lisraya_color_white"
  ],
  "asset_ids": [],
  "governance_ids": [],
  "rule_text": "[GENERAL] Links are Brand Blue #00529b and underlined on light backgrounds; White and underlined on dark backgrounds.",
  "intent": "Ensure links are recognizable and legible on any background.",
  "source": "design_bible",
  "doc_ref": "color_scheme_rules[1]",
  "group_id": "grp_lisraya_color_scheme_rules_01",
  "status": "active",
  "version": 1,
  "summary": "Links are Brand Blue #00529b and underlined on light backgrounds; White and underlined on dark backgrounds."
}