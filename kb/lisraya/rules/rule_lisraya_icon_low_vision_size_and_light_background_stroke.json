  "polarity": "must",
  "hardness": "hard_constraint",
  "precedence": 0,
  "token_ids": [
    "tok_lisraya_color_primary_brand_blue"
  ],
  "asset_ids": [],
  "rule_text": "For low-vision audiences in email, icons must render at a minimum 32\u00d732px; on light backgrounds, use default Brand Blue (#00529b) strokes.",
  "intent": "Preserve icon visibility and legibility for low-vision audiences.",
  "source": "design_bible",
