{
  "id": "rule_lisraya_icon_low_vision_size_and_light_background_stroke",
  "brand_id": "lisraya",
  "rule_class": "accessibility",
  "tags": [
    "iconography"
  ],
  "content_types": [
    "email"
  ],
  "scope": "org_baseline",
  "selector": {
    "element_path": "icon"
  },
  "applies_when": [
