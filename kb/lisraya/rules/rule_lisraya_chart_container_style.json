{
  "id": "rule_lisraya_chart_container_style",
  "brand_id": "lisraya",
  "rule_class": "layout",
  "tags": [
    "color_application"
  ],
  "scope": "brand",
  "selector": {
    "section_types": [
      "chart"
    ],
    "element_path": "chart.container"
  },
  "evaluation_scope": "section",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "chart.container.radius",
        "token_id": "tok_lisraya_radius_chart_uniform"
      },
      {
        "element_path": "chart.container.panel_fill",
        "token_id": "tok_lisraya_color_light_blue"
      },
      {
        "element_path": "chart.container.header_bar",
        "token_id": "tok_lisraya_color_brand_blue"
      }
    ]
  },
  "polarity": "must",
  "hardness": "hard_constraint",
  "precedence": 0,
  "token_ids": [
    "tok_lisraya_color_brand_blue",
    "tok_lisraya_color_light_blue",
    "tok_lisraya_radius_chart_uniform"
  ],
  "asset_ids": [],
  "governance_ids": [],
  "rule_text": "Chart and infographic containers use uniform rounded corners (12px), a Light Blue (#E6F0F9) panel, and a Brand Blue (#00529b) rounded header bar.",
  "intent": "Keep charts clean, scannable, and consistent with the visual system.",
  "source": "design_bible",
  "doc_ref": "design_pattern_rules[4]",
  "group_id": "grp_lisraya_design_pattern_rules_04",
  "status": "active",
  "version": 1,
  "summary": "Chart and infographic containers have 12px rounded corners, Light Blue (#E6F0F9) panel, and Brand Blue (#00529b) rounded header bar."
