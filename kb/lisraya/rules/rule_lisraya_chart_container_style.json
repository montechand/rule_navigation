{
  "id": "rule_lisraya_chart_container_style",
  "brand_id": "lisraya",
  "rule_class": "layout",
  "tags": [
    "color_application",
    "layout"
  ],
  "scope": "brand",
  "selector": {
    "section_types": [
      "chart"
    ],
    "element_path": "chart.container"
  },
  "evaluation_scope": "section",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "chart.container.radius",
        "token_id": "tok_lisraya_chart_container_radius"
      },
      {
        "element_path": "chart.panel.fill",
        "token_id": "tok_lisraya_chart_panel_fill"
      },
      {
        "element_path": "chart.header.fill",
        "token_id": "tok_lisraya_chart_header_fill"
      }
    ]
  },
  "polarity": "must",
  "hardness": "strong_default",
  "precedence": 0,
  "token_ids": [
    "tok_lisraya_chart_container_radius",
    "tok_lisraya_chart_header_fill",
    "tok_lisraya_chart_panel_fill"
  ],
  "asset_ids": [],
  "governance_ids": [],
  "rule_text": "Charts and infographics use a clean, scannable container consistent with the system: uniform rounded corners (chart.container.radius), a Light Blue panel fill (chart.panel.fill = #E6F0F9) with a Brand Blue rounded header bar (chart.header.fill = #00529b).",
  "intent": "Keep data visualizations clean, scannable and on-system.",
  "source": "design_bible",
  "doc_ref": "design_pattern_rules[4]",
  "group_id": "grp_lisraya_design_pattern_rules_04",
  "status": "active",
  "version": 1,
  "summary": "Charts use containers with uniform rounded corners, Light Blue (#E6F0F9) panel fill, and Brand Blue (#00529b) rounded header bars for clean, scannable layout."
}