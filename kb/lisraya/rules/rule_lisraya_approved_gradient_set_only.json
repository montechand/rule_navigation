{
  "id": "rule_lisraya_approved_gradient_set_only",
  "brand_id": "lisraya",
  "rule_class": "color_application",
  "tags": [
    "imagery"
  ],
  "scope": "brand",
  "selector": {
    "element_path": "background.gradient"
  },
  "evaluation_scope": "element",
  "constraint_type": "binding",
  "effect": {
    "assignments": [
      {
        "element_path": "background.gradient.brand_blue_dark_navy",
        "token_id": "tok_lisraya_color_primary_brand_blue"
      },
      {
        "element_path": "background.gradient.brand_blue_dark_navy.stop2",
        "token_id": "tok_lisraya_color_secondary_dark_navy"
      },
      {
        "element_path": "background.gradient.sky_deep_blue.stop1",
        "token_id": "tok_lisraya_color_secondary_sky_blue"
      },
      {
        "element_path": "background.gradient.sky_deep_blue.stop2",
        "token_id": "tok_lisraya_color_secondary_deep_blue"
      },
      {
        "element_path": "background.gradient.sunshine_gold.stop1",
        "token_id": "tok_lisraya_background_gradient_cta_fallback"
      },
      {
        "element_path": "background.gradient.sunshine_gold.stop2",
        "token_id": "tok_lisraya_opacity_gold75_gradient_stop"
      },
      {
        "element_path": "background.gradient.golden_sand_white_light_blue.stop1",
        "token_id": "tok_lisraya_color_tertiary_golden_sand"
      },
      {
        "element_path": "background.gradient.golden_sand_white_light_blue.stop2",
        "token_id": "tok_lisraya_color_tertiary_white"
      },
      {
        "element_path": "background.gradient.golden_sand_white_light_blue.stop3",
        "token_id": "tok_lisraya_color_tertiary_light_blue"
      }
    ]
  },
  "polarity": "must",
  "hardness": "hard_constraint",
  "precedence": 0,
  "token_ids": [
    "tok_lisraya_background_gradient_cta_fallback",
    "tok_lisraya_color_primary_brand_blue",
    "tok_lisraya_color_secondary_dark_navy",
    "tok_lisraya_color_secondary_deep_blue",
    "tok_lisraya_color_secondary_sky_blue",
    "tok_lisraya_color_tertiary_golden_sand",
    "tok_lisraya_color_tertiary_light_blue",
    "tok_lisraya_color_tertiary_white",
    "tok_lisraya_opacity_gold75_gradient_stop"
  ],
  "asset_ids": [],
  "rule_text": "Only the approved gradient set may be used \u2014 never invent gradients. Approved gradients and their usages: Brand Blue \u2192 Dark Navy (#00529b \u2192 #011E45) for dark backgrounds and blue masthead/waves; Sky Blue \u2192 Deep Blue (#358CCB \u2192 #003D74) for blue backgrounds and waves; Sunshine \u2192 75% Gold (#faa31b \u2192 Gold @75%) for warm backgrounds; Golden Sand \u2192 White \u2192 Light Blue (#FEF1C8 \u2192 #ffffff \u2192 #E6F0F9) for soft light backgrounds; and Golden Sand \u2192 75% Gold \u2192 Sunshine (#FEF1C8 \u2192 Gold @75% \u2192 #faa31b) for warm light-to-saturated backgrounds. Gradients are used as backgrounds, in combination with the wave graphic, and with the LISRAYA logo mark \u2014 approved values only.",
  "intent": "Preserve brand color integrity by limiting gradients to the sanctioned palette.",
  "source": "design_bible",
  "doc_ref": "color_scheme_rules[3]",
  "group_id": "grp_lisraya_color_scheme_rules_03",
  "status": "active",
  "version": 1,
  "summary": "Use only approved gradients: Brand Blue (#00529b\u2192#011E45) for dark/bg waves, Sky Blue (#358CCB\u2192#003D74) for blue bg/waves, Sunshine (#faa31b\u2192Gold 75%) warm bg, Golden Sand\u2192White\u2192Light Blue or Golden Sand\u2192Gold 75%\u2192Sunshine for light backgrounds and LISRAYA logo; no invented gradients."
}