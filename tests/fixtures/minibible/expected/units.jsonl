{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0023", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 23, "start": 558, "end": 559, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Typography"]}
