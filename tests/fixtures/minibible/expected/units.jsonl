{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0045", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 45, "start": 998, "end": 999, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Editorial"]}
{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0046", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 46, "start": 999, "end": 1058, "kind": "sentence", "text": "Our brand journey celebrates wellness in everyday moments.\n", "heading_path": ["Brand Foundation", "Editorial"]}
{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0047", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 47, "start": 1058, "end": 1059, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Editorial"]}
{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0048", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 48, "start": 1059, "end": 1160, "kind": "sentence", "text": "For example, you might show a smiling patient hiking — this is illustrative only, not a requirement.\n", "heading_path": ["Brand Foundation", "Editorial"]}
