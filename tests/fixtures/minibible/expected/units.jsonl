{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0041", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 41, "start": 837, "end": 838, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Required Disclosure"]}
