{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0008", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 8, "start": 220, "end": 273, "kind": "sentence", "text": "Do not use Accent Teal outside LPGA-gated materials.\n", "heading_path": ["Brand Foundation", "Color Palette"]}
{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0009", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 9, "start": 273, "end": 274, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Color Palette"]}
