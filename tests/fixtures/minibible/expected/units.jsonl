{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0021", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 21, "start": 518, "end": 519, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Typography"]}
