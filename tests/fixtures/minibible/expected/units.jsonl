{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0019", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 19, "start": 454, "end": 455, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Typography"]}
