{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0043", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 43, "start": 984, "end": 985, "kind": "blank", "text": "\n", "heading_path": ["Brand Foundation", "Required Disclosure"]}
