{"schema_version": "2.0", "unit_id": "u_brand_foundation_0_0005", "brand_id": "minibible", "doc_ref": "brand_foundation[0]", "ordinal": 5, "start": 85, "end": 145, "kind": "sentence", "text": "Brand Teal #01A47E is an approved alias for the same value.\n", "heading_path": ["Brand Foundation", "Color Palette"]}
