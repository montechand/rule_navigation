    {
      "description": "The entire 'Tint Rules' section mandates specific, exclusive tint percentages (40% for campaign headline D/M, 70% for Light Blue callout & wave layers, 30% for Golden Sand callout, plus 75% Gold in two gradient stops), stating 'No other ad-hoc tints — use palette values or these specified tints only.' None of these percentage values exist as primitive tokens anywhere in the catalog.",
      "finding_id": "f_lisraya_001",
      "finding_type": "omission",
      "proposed_patch": {
        "entity_kind": "token_primitive",
        "op": "add",
        "payload": {
          "tokens": [
            {
              "default": "40%",
              "key": "tint.headline_letter.40"
            },
            {
              "default": "70%",
              "key": "tint.light_blue_callout.70"
            },
            {
              "default": "30%",
              "key": "tint.golden_sand_callout.30"
            },
            {
              "default": "75%",
              "key": "tint.gold_gradient.75"
            }
          ]
        },
        "target_entity_ids": []
      },
      "severity": "critical",
      "target_entity_id": null,
