{
  "findings": [
    {
      "description": "The entire 'Tint Rules' governance section (40% tint on campaign headline D/M, 70% Light Blue callout tint, 30% Golden Sand callout tint, 70% wave transparency, and the explicit 'no other ad-hoc tints' constraint) has no corresponding tokens. Only the resulting radii/paddings for those components exist, not the tint percentage values themselves, despite this being an explicit closed-set rule.",
      "finding_id": "f_lisraya_001",
      "finding_type": "omission",
      "proposed_patch": {
        "entity_kind": "token_primitive",
        "op": "add",
        "payload": {
          "tokens": [
            {
              "default": "40%",
              "key": "tint.campaign_headline.40"
            },
            {
              "default": "70%",
              "key": "tint.callout.light_blue_70"
            },
            {
              "default": "30%",
              "key": "tint.callout.golden_sand_30"
            },
            {
              "default": "70%",
              "key": "transparency.wave_top_70"
            }
          ]
        },
        "target_entity_ids": []
      },
      "severity": "critical",
      "target_entity_id": null,
      "unit_ids": [
