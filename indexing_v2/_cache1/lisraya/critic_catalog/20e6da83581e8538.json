{
  "findings": [
    {
      "description": "The entire 'Graphic Elements — Waves' pattern (two colorways: Sunshine/Gold and Sky Blue/Deep Blue; long/short variants; 70% transparency layering; masthead gradient device) has no corresponding subtype, asset, or semantic tokens in the catalog, unlike Gradient Callout CTA and Icon Callout Box which each got a dedicated subtype.",
      "finding_id": "f_lisraya_001",
      "finding_type": "omission",
      "proposed_patch": {
        "entity_kind": "subtype",
        "op": "add",
        "payload": {
          "lengths": [
            "long",
            "short"
          ],
          "name": "Wave Graphic",
          "opacity": 0.7,
          "variants": [
            "sunshine_gold",
            "sky_blue_deep_blue"
          ]
        },
        "target_entity_ids": []
      },
      "severity": "critical",
      "target_entity_id": null,
      "unit_ids": [
        "u_design_pattern_rules_1_0000",
