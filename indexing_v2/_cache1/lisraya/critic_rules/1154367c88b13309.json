      "finding_type": "bad_cluster",
      "proposed_patch": {
        "entity_kind": "rule",
        "op": "split",
        "payload": {
          "doc_ref": "internal_banner_rules[0]",
          "group_id": "grp_lisraya_internal_banner_rules_00",
          "rules": [
            {
              "class": "typography",
              "font": "Agenda",
              "hardness": "strong_default",
              "polarity": "should",
              "scope": "headlines_headers"
            },
            {
              "class": "typography",
              "font": "Nunito Sans",
              "hardness": "strong_default",
              "polarity": "should",
              "scope": "body_copy_print"
            }
          ]
        },
