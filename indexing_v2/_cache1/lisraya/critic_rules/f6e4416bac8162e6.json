{
  "findings": [
    {
      "description": "This rule conflates two distinct facts: the fixed verbatim program name 'My Compass Support' (a copy_editorial verbatim requirement) and the program's operational scope (PAL channels: text/phone/email/in-person; Authorization Support). The scope description is not verbatim campaign copy and belongs to a different rule class (e.g., program_scope/support_services), so bundling it under copy_editorial hard_constraint/must misrepresents its nature.",
      "finding_id": "f_lisraya_01",
      "finding_type": "bad_cluster",
      "proposed_patch": {
        "entity_kind": "rule",
        "op": "split",
        "payload": {
          "doc_ref": "content_pattern_rules[7]",
          "group_id": "grp_lisraya_content_pattern_rules_07",
          "new_rules": [
            {
              "class": "copy_editorial",
              "hardness": "hard_constraint",
              "id": "rule_lisraya_support_program_name_verbatim",
              "polarity": "must"
            },
            {
              "class": "program_scope",
              "hardness": "soft_constraint",
              "id": "rule_lisraya_support_program_scope",
              "polarity": "should"
            }
          ]
        },
        "target_entity_ids": [
          "rule_lisraya_support_program_name_and_scope"
        ]
      },
      "severity": "major",
      "target_entity_id": "rule_lisraya_support_program_name_and_scope",
      "unit_ids": [
        "u_content_pattern_rules_7_0007"
      ]
    },
    {
      "description": "The bullet copy includes a regulatory claim ('FDA-approved') and clinical benefit claims (muscle strength, skin symptoms, steroid reliance) that typically require substantiation/regulatory review governance facets (e.g., reviewed_by, claim_substantiation_ref). No governance metadata is attached to this hard_constraint rule.",
      "finding_id": "f_lisraya_02",
      "finding_type": "governance_miss",
      "proposed_patch": {
        "entity_kind": "rule",
        "op": "update",
        "payload": {
          "add_facets": {
