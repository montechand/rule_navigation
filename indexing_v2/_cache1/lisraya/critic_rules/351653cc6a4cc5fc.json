        "payload": {
          "doc_ref": "color_scheme_rules[2]",
          "group_id": "grp_lisraya_color_scheme_rules_02",
          "new_rules": [
            {
              "id": "rule_lisraya_headline_tint",
              "scope": "campaign headline D/M",
              "value": "40% tint of headline color (Gold or Brand Blue)"
            },
            {
              "id": "rule_lisraya_lightblue_callout_tint",
              "scope": "Light Blue callout box",
              "value": "70% tint"
            },
            {
              "id": "rule_lisraya_goldensand_callout_tint",
              "scope": "Golden Sand callout box",
              "value": "30% tint"
            },
            {
              "id": "rule_lisraya_wave_transparency",
              "scope": "Wave top layers",
              "value": "70% transparency"
            },
            {
              "id": "rule_lisraya_no_adhoc_tints",
              "polarity": "must_not",
              "scope": "all tint usage",
              "value": "no ad-hoc tints outside palette or specified values"
            }
          ]
        },
        "target_entity_ids": [
          "rule_lisraya_approved_tint_levels"
        ]
      },
      "severity": "major",
      "target_entity_id": "rule_lisraya_approved_tint_levels",
