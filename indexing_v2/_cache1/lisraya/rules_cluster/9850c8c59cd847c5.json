      "governance": null,
      "hardness": "hard_constraint",
      "intent": "Maintain exact brand geometry, asymmetry ratios, and shadow depth for proof-point callouts across email clients.",
      "polarity": "must",
      "precedence": 0,
      "rule_class": "layout",
      "rule_text": "The Icon Callout Box uses a Light Blue (#E6F0F9) accent-shape container with asymmetrical corner radii (icon_callout.box.radius = 40px 8px 40px 8px). It features a White (#ffffff) icon badge offset on the left edge by exactly half its width (W/2 = 40px for W = 80px), mirroring the container's asymmetrical radii at a smaller scale (icon_callout.badge.radius = 20px 4px 20px 4px) and carrying a subtle drop shadow (icon_callout.badge.shadow = 0 4px 10px rgba(1, 30, 69, 0.18)). Text must be left-aligned and vertically centered, utilizing Nunito Sans weight 800 in Brand Blue (#00529b).",
      "scope": "brand",
      "selector": {
        "element_path": "icon_callout",
        "section_types": [
          "callout"
        ]
      },
      "slug": "icon_callout_box_rule",
      "snippets": "<div style=\"position:relative; padding-left:40px;\">\n\n        <!-- Light Blue accent-shape box (large TL+BR, point TR+BL = 5:1) -->\n        <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"border-collapse:separate;\">\n          <tr>\n            <td style=\"background-color:#E6F0F9; border-radius:40px 8px 40px 8px; padding:26px 34px 26px 64px;\">\n              <span style=\"font-family:'Nunito Sans',Arial,Helvetica,sans-serif; font-size:21px; line-height:28px; font-weight:800; color:#00529b;\">\n                These improvements occurred as early as four weeks after starting treatment, and they continued getting better through the end of the 52-week study.\n              </span>\n            </td>\n          </tr>\n        </table>\n\n        <!-- White icon badge: mirrors accent radii (20/4/20/4), drop shadow, centered on the edge -->\n        <div style=\"position:absolute; left:0; top:50%; margin-top:-40px; width:80px; height:80px; background-color:#ffffff; border-radius:20px 4px 20px 4px; box-shadow:0 4px 10px rgba(1,30,69,0.18); text-align:center; line-height:80px;\">\n          <img src=\"ICON_URL\" alt=\"\" width=\"48\" height=\"48\" style=\"vertical-align:middle; border:0;\" />\n        </div>\n\n      </div>",
